{
  "name": "minibum",
  "version": "2.0.8",
  "description": "🍬@2 This is an educational project that explores state management,reactive UI patterns, and DOM rendering using plain JavaScript. it has two parts the core and a wrapper.",
  "module": "./dist/minibum.wrapper.js",
  "types": "./dist/wrapper.d.ts",
  "exports": {
    ".": {
      "types": "./dist/wrapper.d.ts",
      "import": "./dist/minibum.wrapper.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/minibum.core.js"
    },
    "./min": {
      "import": "./dist/minibum.wrapper.min.js"
    },
    "./core.min": {
      "import": "./dist/minibum.core.min.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "!dist/**/*.min.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guifendjy/mini-bum.git"
  },
  "scripts": {
    "build": "rollup -c && npm run build:types",
    "build:watch": "rollup -c -w",
    "build:types": "npx tsc -p tsconfig.core.json && npx tsc -p tsconfig.wrapper.json"
  },
  "keywords": [
    "vanilla-js",
    "javascript",
    "state-management",
    "signal",
    "dom",
    "reactive",
    "ui",
    "minibum",
    "mini-bum"
  ],
  "author": "Dads Guifendjy Paul",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^2.79.2",
    "rollup-plugin-terser": "^4.0.3"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
